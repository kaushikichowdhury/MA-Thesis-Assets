      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        ">*Function to classify poems as the regularly seen meters in poems:*\n",
        ">\n",
        ">*For each poem’s average number of feet, it is remade as the corresponding metre type (e.g., pentameter, tetrameter)*"
      ],
      "metadata": {
        "id": "MHnSJu1aqLnE"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def feet_to_meter(n):\n",
        "\n",
        "    if pd.isna(n):\n",
        "        return \"irregular\"\n",
        "\n",
        "    n = round(n)\n",
        "\n",
        "    if n == 1:\n",
        "        return \"monometer\"\n",
        "    elif n == 2:\n",
        "        return \"dimeter\"\n",
        "    elif n == 3:\n",
        "        return \"trimeter\"\n",
        "    elif n == 4:\n",
        "        return \"tetrameter\"\n",
        "    elif n == 5:\n",
        "        return \"pentameter\"\n",
        "    elif n == 6:\n",
        "        return \"hexameter\"\n",
        "    else:\n",
        "        return \"irregular\"\n",
        "\n",
        "metre_type = dominant_meter.apply(feet_to_meter)"
      ],
      "metadata": {
        "id": "7ulPgMskurAo"
      },
      "execution_count": null,
      "outputs": []
    },
