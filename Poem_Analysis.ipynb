    {
      "cell_type": "code",
      "source": [
        "dominant_foot = (\n",
        "    scansion_df\n",
        "    .groupby(\"poem\")[\"foot\"]\n",
        "    .agg(lambda x: x.value_counts().idxmax())\n",
        ")\n",
        "\n",
        "dominant_meter = scansion_df.groupby(\"poem\")[\"meter\"].mean()"
      ],
