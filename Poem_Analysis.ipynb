    {
      "cell_type": "code",
      "source": [
        "target_poems = [\"A28\", \"A37\", \"C01\", \"C04\", \"L04\", \"L11\"]\n",
        "selected_poems = poems_for_enjambment[poems_for_enjambment['Poem ID'].isin(target_poems)]"
