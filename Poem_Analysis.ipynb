      "source": [
        ">*Function to extract Metaphors*\n",
        ">\n",
        ">*This runs the text through the model and returns only words/phrases that are metaphors.*"
      ],
      "metadata": {
        "id": "ZpJItTpOZY-y"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def get_metaphors(text):\n",
        "    results = metaphor_pipeline(text)\n",
        "    return [r[\"word\"] for r in results if r[\"entity_group\"] == \"LABEL_1\"]  # Keeping only metaphor-having labels"
      ],
      "metadata": {
        "id": "YHFHTkkaXAew"
      },
      "execution_count": null,
      "outputs": []
    },
